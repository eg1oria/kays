@startuml
title Use Case Diagram - AI Vision Conveyor Monitoring System
left to right direction

actor "Камера" as Camera
actor "ИИ-модуль" as AIModule
actor "Робот-манипулятор" as Robot
actor "Оператор" as Operator

rectangle "AI Vision Conveyor Monitoring System" {
  usecase "Передать\nвидеопоток" as UC1
  usecase "Проанализировать\nизображение" as UC2
  usecase "Обнаружить\nдефект" as UC3
  usecase "Отправить команду\nроботу" as UC4
  usecase "Удалить товар\nс конвейера" as UC5
  usecase "Просмотреть\nотчет" as UC6
}

Camera --> UC1
AIModule --> UC2
AIModule --> UC3
AIModule --> UC4
Robot --> UC5
Operator --> UC6

UC1 ..> UC2 : <<include>>
UC2 ..> UC3 : <<include>>
UC3 ..> UC4 : <<include>>
UC4 ..> UC5 : <<include>>
@enduml
